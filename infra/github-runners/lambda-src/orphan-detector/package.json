{
  "name": "reinhardt-ci-orphan-detector",
  "version": "1.0.0",
  "description": "Scheduled Lambda scanning for stranded GitHub Actions jobs (Issue #3903)",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "test": "vitest run",
